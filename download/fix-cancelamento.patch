diff --git a/app/routes/orders.py b/app/routes/orders.py
index 42b3eb0..d6842ed 100644
--- a/app/routes/orders.py
+++ b/app/routes/orders.py
@@ -187,3 +187,69 @@ async def dispatch_order(ifood_order_id: str):
     except Exception as e:
         logger.error("Failed to dispatch order %s: %s", ifood_order_id, e)
         raise HTTPException(status_code=500, detail=f"Failed to dispatch order: {str(e)}")
+
+
+@router.post("/{ifood_order_id}/accept-cancellation")
+async def accept_cancellation(ifood_order_id: str):
+    """Aceita solicitacao de cancelamento no iFood e atualiza Odoo.
+
+    Endpoint manual para testes de homologacao. Em producao,
+    o fluxo e automatico via webhook (evento CAN/CANCELLATION_REQUESTED).
+    """
+    logger.info("[CANCELLATION] Aceitacao manual de cancelamento para pedido %s", ifood_order_id)
+
+    try:
+        # 1. Enviar aceitacao ao iFood
+        async with IFoodAPIClient(settings) as ifood_client:
+            result = await ifood_client.accept_cancellation(ifood_order_id)
+
+        logger.info("[CANCELLATION] iFood aceitou o cancelamento: %s", result)
+
+        # 2. Atualizar Odoo
+        odoo_client = OdooClient(settings)
+        sync_service = OdooSyncService(odoo_client, ifood_client)
+        sync_service.update_order_status(ifood_order_id, "cancelled")
+
+        return {
+            "status": "ok",
+            "message": f"Cancellation accepted for order {ifood_order_id}",
+            "ifood_response": result,
+        }
+
+    except Exception as e:
+        logger.error("[CANCELLATION] Falha ao aceitar cancelamento do pedido %s: %s",
+                     ifood_order_id, e, exc_info=True)
+        raise HTTPException(
+            status_code=500,
+            detail=f"Failed to accept cancellation: {str(e)}",
+        )
+
+
+@router.post("/{ifood_order_id}/reject-cancellation")
+async def reject_cancellation(ifood_order_id: str, reason: str = ""):
+    """Rejeita solicitacao de cancelamento no iFood.
+
+    Endpoint manual para testes de homologacao.
+    """
+    logger.info("[CANCELLATION] Rejeicao manual de cancelamento para pedido %s - Motivo: %s",
+                ifood_order_id, reason)
+
+    try:
+        async with IFoodAPIClient(settings) as ifood_client:
+            result = await ifood_client.reject_cancellation(ifood_order_id, reason)
+
+        logger.info("[CANCELLATION] iFood rejeitou o cancelamento: %s", result)
+
+        return {
+            "status": "ok",
+            "message": f"Cancellation rejected for order {ifood_order_id}",
+            "ifood_response": result,
+        }
+
+    except Exception as e:
+        logger.error("[CANCELLATION] Falha ao rejeitar cancelamento do pedido %s: %s",
+                     ifood_order_id, e, exc_info=True)
+        raise HTTPException(
+            status_code=500,
+            detail=f"Failed to reject cancellation: {str(e)}",
+        )
diff --git a/app/services/ifood_api.py b/app/services/ifood_api.py
index 880b831..08e81f4 100644
--- a/app/services/ifood_api.py
+++ b/app/services/ifood_api.py
@@ -181,6 +181,55 @@ class IFoodAPIClient:
             json_body={"reason": reason},
         )
 
+    async def accept_cancellation(self, order_id: str) -> dict:
+        """Aceita uma solicitacao de cancelamento de pedido no iFood.
+
+        Quando o iFood envia o evento cancellationRequested (codigo CAN/CAR),
+        a integracao DEVE chamar este endpoint para confirmar o cancelamento.
+        Sem isso, o iFood considera que a integracao nao processou o cancelamento.
+
+        Args:
+            order_id: O ID do pedido no iFood.
+
+        Returns:
+            Resposta do iFood.
+        """
+        logger.info("[CANCELLATION] Aceitando cancelamento do pedido %s no iFood", order_id)
+        logger.info("[CANCELLATION] Chamando POST /order/v1.0/orders/%s/cancellation/accept", order_id)
+        try:
+            result = await self._request(
+                "POST",
+                f"/order/v1.0/orders/{order_id}/cancellation/accept",
+            )
+            logger.info("[CANCELLATION] Cancelamento ACEITO com sucesso para pedido %s - Resposta: %s",
+                        order_id, result)
+            return result
+        except Exception as e:
+            logger.error("[CANCELLATION] FALHA ao aceitar cancelamento do pedido %s: %s", order_id, e,
+                         exc_info=True)
+            raise
+
+    async def reject_cancellation(self, order_id: str, reason: str = "") -> dict:
+        """Rejeita uma solicitacao de cancelamento de pedido no iFood.
+
+        Args:
+            order_id: O ID do pedido no iFood.
+            reason: Motivo da rejeicao (opcional).
+
+        Returns:
+            Resposta do iFood.
+        """
+        logger.info("[CANCELLATION] Rejeitando cancelamento do pedido %s no iFood - Motivo: %s",
+                    order_id, reason)
+        body = {}
+        if reason:
+            body["reason"] = reason
+        return await self._request(
+            "POST",
+            f"/order/v1.0/orders/{order_id}/cancellation/reject",
+            json_body=body if body else None,
+        )
+
     # ── Catalog ────────────────────────────────────────────────
 
     async def get_catalog(self, merchant_id: str) -> dict:
