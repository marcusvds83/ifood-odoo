+            elif event_type in ("CAR", "CANCELLATION_ACCEPTED"):
+                # Evento de confirmacao do iFood de que o cancelamento foi processado
+                logger.info("[CANCELLATION] Cancelamento confirmado pelo iFood para pedido %s", order_id)
                 sync_service.update_order_status(order_id, "cancelled")
-                logger.info("Pedido %s marcado como cancelado", order_id)
+                logger.info("[CANCELLATION] Status 'cancelled' reconfirmado no Odoo para pedido %s", order_id)
 
