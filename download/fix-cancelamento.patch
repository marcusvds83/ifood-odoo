@@ -106,20 +106,54 @@ async def handle_order_webhook(request: Request, response: Response):
 
         try:
             if event_type in ("PLC", "NEW", "orderCreated", "placed"):
+                logger.info("[PLC] Novo pedido recebido: %s", order_id)
                 async with ifood_client:
                     order_data = await ifood_client.get_order(order_id)
                 sale_order_id = sync_service.sync_order(order_data)
-                logger.info("Pedido %s sincronizado -> Odoo sale.order %s", order_id, sale_order_id)
+                logger.info("[PLC] Pedido %s sincronizado -> Odoo sale.order %s", order_id, sale_order_id)
 
             elif event_type == "orderStatusChanged":
                 status = payload.get("newStatus", payload.get("status", ""))
+                logger.info("[STATUS_CHANGE] Pedido %s - novo status: %s", order_id, status)
                 if status:
                     sync_service.update_order_status(order_id, status)
-                    logger.info("Pedido %s status atualizado: %s", order_id, status)
-
-            elif event_type in ("CAN", "CANCELLATION_REQUESTED", "CAR", "orderCancelled", "cancelled"):
+                    logger.info("[STATUS_CHANGE] Pedido %s status atualizado no Odoo: %s", order_id, status)
+
+            elif event_type in ("CAN", "CANCELLATION_REQUESTED", "cancellationRequested"):
+                # ── CANCELAMENTO: fluxo critico para homologacao ──
+                logger.info("[CANCELLATION] === INICIO FLUXO DE CANCELAMENTO ===")
+                logger.info("[CANCELLATION] Evento: %s | Pedido: %s | Merchant: %s",
+                            event_type, order_id, merchant_id)
+                logger.info("[CANCELLATION] Payload completo: %s",
+                            body.decode("utf-8", errors="replace")[:3000])
+
+                cancellation_reason = payload.get("reason", payload.get("cancellationReason", "nao informado"))
+                logger.info("[CANCELLATION] Motivo do cancelamento: %s", cancellation_reason)
+
+                # 1. Atualizar status no Odoo
+                odoo_updated = sync_service.update_order_status(order_id, "cancelled")
+                logger.info("[CANCELLATION] Odoo atualizado para 'cancelled': %s (pedido %s)",
+                            odoo_updated, order_id)
+
+                # 2. ENVIAR CONFIRMACAO DE CANCELAMENTO PARA O IFOOD
+                #    Este eh o passo que faltava - sem isso o iFood reprovava a homologacao
+                try:
+                    async with ifood_client:
+                        accept_result = await ifood_client.accept_cancellation(order_id)
+                    logger.info("[CANCELLATION] Confirmacao de cancelamento ENVIADA ao iFood com sucesso")
+                    logger.info("[CANCELLATION] Resposta do iFood: %s", accept_result)
+                except Exception as cancel_err:
+                    logger.error("[CANCELLATION] FALHA ao enviar confirmacao de cancelamento ao iFood: %s",
